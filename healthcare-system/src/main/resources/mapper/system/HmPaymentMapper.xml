<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.healthcare.system.mapper.HmPaymentMapper">
    
    <resultMap type="HmPayment" id="HmPaymentResult">
        <result property="id"    column="id"    />
        <result property="orderId"    column="order_id"    />
        <result property="payAmount"    column="pay_amount"    />
        <result property="transactionId"    column="transaction_id"    />
        <result property="payDate"    column="pay_date"    />
        <result property="syncFlag"    column="sync_flag"    />
    </resultMap>

    <sql id="selectHmPaymentVo">
        select id, order_id, pay_amount, transaction_id, pay_date, sync_flag from hm_payment
    </sql>

    <select id="selectHmPaymentList" parameterType="HmPayment" resultMap="HmPaymentResult">
        <include refid="selectHmPaymentVo"/>
        <where>  
            <if test="orderId != null "> and order_id = #{orderId}</if>
            <if test="payAmount != null "> and pay_amount = #{payAmount}</if>
            <if test="transactionId != null  and transactionId != ''"> and transaction_id = #{transactionId}</if>
            <if test="payDate != null "> and pay_date = #{payDate}</if>
            <if test="hasPayed == 1 "> and pay_date IS NOT NULL</if>
            <if test="syncFlag != null "> and sync_flag = #{syncFlag}</if>
        </where>
    </select>
    
    <select id="selectHmPaymentById" parameterType="Long" resultMap="HmPaymentResult">
        <include refid="selectHmPaymentVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertHmPayment" parameterType="HmPayment" useGeneratedKeys="true" keyProperty="id">
        insert into hm_payment
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderId != null">order_id,</if>
            <if test="payAmount != null">pay_amount,</if>
            <if test="transactionId != null">transaction_id,</if>
            <if test="payDate != null">pay_date,</if>
            <if test="syncFlag != null">sync_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderId != null">#{orderId},</if>
            <if test="payAmount != null">#{payAmount},</if>
            <if test="transactionId != null">#{transactionId},</if>
            <if test="payDate != null">#{payDate},</if>
            <if test="syncFlag != null">#{syncFlag},</if>
         </trim>
    </insert>

    <update id="updateHmPayment" parameterType="HmPayment">
        update hm_payment
        <trim prefix="SET" suffixOverrides=",">
            <if test="orderId != null">order_id = #{orderId},</if>
            <if test="payAmount != null">pay_amount = #{payAmount},</if>
            <if test="transactionId != null">transaction_id = #{transactionId},</if>
            <if test="payDate != null">pay_date = #{payDate},</if>
            <if test="syncFlag != null">sync_flag = #{syncFlag},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteHmPaymentById" parameterType="Long">
        delete from hm_payment where id = #{id}
    </delete>

    <delete id="deleteHmPaymentByIds" parameterType="String">
        delete from hm_payment where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>