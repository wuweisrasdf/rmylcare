<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.healthcare.system.mapper.HmMotherMapper">
    
    <resultMap type="HmMother" id="HmMotherResult">
        <result property="id"    column="id"    />
        <result property="userId"    column="user_id"    />
        <result property="motherRelation"    column="mother_relation"    />
        <result property="motherName"    column="mother_name"    />
        <result property="email"    column="email"    />
        <result property="phonenumber"    column="phonenumber"    />
        <result property="idType"    column="id_type"    />
        <result property="idCode"    column="id_code"    />
        <result property="hospitalName"    column="hospital_name"    />
        <result property="dueDate"    column="due_date"    />
        <result property="address"    column="address"    />
    </resultMap>

    <sql id="selectHmMotherVo">
        select id, user_id, mother_relation, mother_name, email, phonenumber, id_type, id_code, hospital_name, due_date, address from hm_mother
    </sql>

    <select id="selectHmMotherList" parameterType="HmMother" resultMap="HmMotherResult">
        <include refid="selectHmMotherVo"/>
        <where>  
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="motherRelation != null  and motherRelation != ''"> and mother_relation = #{motherRelation}</if>
            <if test="motherName != null  and motherName != ''"> and mother_name like concat('%', #{motherName}, '%')</if>
            <if test="email != null  and email != ''"> and email = #{email}</if>
            <if test="phonenumber != null  and phonenumber != ''"> and phonenumber = #{phonenumber}</if>
            <if test="idType != null  and idType != ''"> and id_type = #{idType}</if>
            <if test="idCode != null  and idCode != ''"> and id_code = #{idCode}</if>
            <if test="hospitalName != null  and hospitalName != ''"> and hospital_name like concat('%', #{hospitalName}, '%')</if>
            <if test="dueDate != null "> and due_date = #{dueDate}</if>
            <if test="address != null  and address != ''"> and address = #{address}</if>
        </where>
    </select>
    
    <select id="selectHmMotherById" parameterType="Long" resultMap="HmMotherResult">
        <include refid="selectHmMotherVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertHmMother" parameterType="HmMother" useGeneratedKeys="true" keyProperty="id">
        insert into hm_mother
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="motherRelation != null">mother_relation,</if>
            <if test="motherName != null">mother_name,</if>
            <if test="email != null">email,</if>
            <if test="phonenumber != null">phonenumber,</if>
            <if test="idType != null">id_type,</if>
            <if test="idCode != null">id_code,</if>
            <if test="hospitalName != null">hospital_name,</if>
            <if test="dueDate != null">due_date,</if>
            <if test="address != null">address,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="motherRelation != null">#{motherRelation},</if>
            <if test="motherName != null">#{motherName},</if>
            <if test="email != null">#{email},</if>
            <if test="phonenumber != null">#{phonenumber},</if>
            <if test="idType != null">#{idType},</if>
            <if test="idCode != null">#{idCode},</if>
            <if test="hospitalName != null">#{hospitalName},</if>
            <if test="dueDate != null">#{dueDate},</if>
            <if test="address != null">#{address},</if>
         </trim>
    </insert>

    <update id="updateHmMother" parameterType="HmMother">
        update hm_mother
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="motherRelation != null">mother_relation = #{motherRelation},</if>
            <if test="motherName != null">mother_name = #{motherName},</if>
            <if test="email != null">email = #{email},</if>
            <if test="phonenumber != null">phonenumber = #{phonenumber},</if>
            <if test="idType != null">id_type = #{idType},</if>
            <if test="idCode != null">id_code = #{idCode},</if>
            <if test="hospitalName != null">hospital_name = #{hospitalName},</if>
            <if test="dueDate != null">due_date = #{dueDate},</if>
            <if test="address != null">address = #{address},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteHmMotherById" parameterType="Long">
        delete from hm_mother where id = #{id}
    </delete>

    <delete id="deleteHmMotherByIds" parameterType="String">
        delete from hm_mother where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>