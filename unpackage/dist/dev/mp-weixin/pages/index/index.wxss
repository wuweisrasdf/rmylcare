.container.data-v-57280228 {
  background-color: #ffffff;
  /* 使用 padding-bottom 为 TabBar 留出空间 */
  padding: 0rpx 26rpx 180rpx 26rpx;
  /* bottom padding >= TabBar高度(100rpx) + 安全区(～40rpx) */
  min-height: 100vh;
  box-sizing: border-box;
  /* 确保 padding 包含在 100vh 内 */
}
